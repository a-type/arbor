---
export interface Props {
	value: string;
	name: string;
}
const { value, name, ...props } = Astro.props;
---

<label class="select-chip" {...props}>
	<input type="checkbox" name={name} value={value} class="select-chip-input" />
	<div class="select-chip-content">
		<slot />
	</div>
</label>

<style>
	.select-chip {
		@apply --mx-shadow;
		@apply --mx-fg(var(--m-action-ambient-fg));
		@apply --mx-bg(var(--m-action-ambient-bg));
		@apply --mx-border(var(--m-action-ambient-border));
		border-radius: var(--m-action-radius);
		padding: var(--m-action-padding);
		font-size: var(--m-text-secondary-size);
		line-height: 1;
		font-weight: var(--m-primitive-typography-weight-bold);
		cursor: pointer;
		display: block;

		&:has(.select-chip-input:checked) {
			@apply --mx-fg(var(--m-action-primary-fg));
			@apply --mx-bg(var(--m-action-primary-bg));
			@apply --mx-border(var(--m-action-primary-border));
		}

		@apply --mx-disabled;
		@apply --mx-hover;
		@apply --mx-focus;
		@apply --mx-active;
	}
	.select-chip-input {
		visibility: hidden;
		position: absolute;
		width: 0;
		height: 0;
		overflow: clip;
	}
</style>
