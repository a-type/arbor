---
interface Props {
	tag?: 'div' | 'section' | 'article' | 'aside' | 'nav';
	emphasis?: 'primary' | 'secondary' | 'ambient';
	bordered?: boolean;
	round?: boolean;
	style?: CSSStyleProperties | string;
	class?: string;
	id?: string;
}
const {
	tag: TagName = 'div',
	emphasis = '',
	bordered = false,
	round = true,
	class: className,
	...rest
} = Astro.props;
---

<TagName
	class:list={['surface', className]}
	data-emphasis={emphasis}
	data-bordered={bordered}
	data-round={round}
	{...rest}
>
	<slot />
</TagName>

<style>
	.surface {
		@apply --mx-surface-ambient;
		border: none;

		&[data-bordered='true'] {
			border: var(--m-surface-ambient-border);
		}

		&[data-emphasis='primary'] {
			@apply --mx-surface-primary;
			border: none;

			&[data-bordered='true'] {
				border: var(--m-surface-primary-border);
			}
		}
		&[data-emphasis='secondary'] {
			@apply --mx-surface-secondary;
			border: none;

			&[data-bordered='true'] {
				border: var(--m-surface-secondary-border);
			}
		}
	}
</style>
