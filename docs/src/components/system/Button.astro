---
export interface Props {
	tag?: 'a' | 'button' | 'label';
	href?: string;
	class?: string;
	emphasis?: 'primary' | 'secondary' | 'ambient';
	id?: string;
	[key: string]: any;
}
const {
	tag: Tag = 'button',
	emphasis = 'primary',
	class: className,
	...props
} = Astro.props;
---

<Tag data-emphasis={emphasis} class:list={['button', className]} {...props}>
	<slot />
</Tag>

<style>
	.button {
		@apply --mx-shadow;
		@apply --mx-action-ambient;

		display: flex;
		flex-direction: row;
		align-items: center;
		gap: var(--m-space-sm);

		transition-property: all;
		transition-duration: var(--m-duration-short);
		transition-timing-function: var(--m-easing);
		cursor: pointer;

		&[data-emphasis='primary'] {
			@apply --mx-action-primary;
		}
		&[data-emphasis='secondary'] {
			@apply --mx-action-secondary;
		}

		@apply --mx-disabled;
		@apply --mx-hover;
		@apply --mx-focus;
		@apply --mx-active;
	}
</style>
