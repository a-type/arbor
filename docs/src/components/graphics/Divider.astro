---
import DividerSection from './DividerSection.astro';

export interface Props {
	class?: string;
}
const { ...props } = Astro.props;
---

<style>
	.divider {
		width: 100%;
		height: 32px;
		display: flex;
		flex-direction: row;
		overflow: clip;
		width: 100%;

		border-left: var(--m-lineWidth) solid var(--m-color-neutral-ink);
		border-right: var(--m-lineWidth) solid var(--m-color-neutral-ink);

		& > svg {
			flex-shrink: 0;
		}
	}
</style>

<div class="divider">
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
	<DividerSection />
</div>
