{
	"name": "@arbor-css/core",
	"version": "0.0.26",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"node": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./runtime": {
			"import": "./dist/runtime/index.js",
			"node": "./dist/runtime/index.js",
			"types": "./dist/runtime/index.d.ts",
			"default": "./dist/runtime/index.js"
		}
	},
	"bin": {
		"arbor": "./dist/cli/run.js"
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "pnpm run --filter @arbor-css/core --parallel \"/^dev:.*/\"",
		"dev:lib": "tsc -w --preserveWatchOutput",
		"dev:demo": "vite ./demo",
		"test": "vitest",
		"test:ci": "vitest --run",
		"predemo:generate": "pnpm build",
		"demo:generate": "node dist/cli/run.js build -c demo/arbor.ts -o demo/arbor.css",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/yargs": "^17.0.35",
		"@vitest/browser-playwright": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vite": "catalog:"
	},
	"dependencies": {
		"@arbor-css/preset": "workspace:*",
		"@arbor-css/tokens": "workspace:*",
		"@arbor-css/globals": "workspace:*",
		"@arbor-css/colors": "workspace:*",
		"@arbor-css/modes": "workspace:*",
		"@arbor-css/typography": "workspace:*",
		"@arbor-css/primitives": "workspace:*",
		"@arbor-css/spacing": "workspace:*",
		"@arbor-css/shadows": "workspace:*",
		"@arbor-css/util": "workspace:*",
		"jiti": "^2.6.1",
		"lil-gui": "^0.21.0",
		"yargs": "^18.0.0"
	}
}
