{
	"name": "arbor-css-vscode",
	"type": "module",
	"displayName": "Arbor CSS",
	"description": "Token autocomplete, hover previews, and validation for Arbor CSS presets",
	"version": "0.0.66",
	"private": true,
	"publisher": "a-type",
	"engines": {
		"vscode": "^1.90.0"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"activationEvents": [
		"onLanguage:css",
		"onLanguage:scss",
		"onLanguage:less"
	],
	"contributes": {
		"languages": [
			{
				"id": "css",
				"aliases": [
					"CSS"
				]
			},
			{
				"id": "scss",
				"aliases": [
					"SCSS"
				]
			},
			{
				"id": "less",
				"aliases": [
					"LESS"
				]
			}
		]
	},
	"main": "./dist/extension.mjs",
	"scripts": {
		"compile": "node esbuild.mjs",
		"build": "pnpm compile && pnpm vsce:package",
		"watch": "node esbuild.mjs --watch",
		"vsce:package": "vsce package --no-dependencies",
		"prepublishOnly": "pnpm compile",
		"test": "vitest",
		"test:ci": "vitest --run"
	},
	"dependencies": {
		"@arbor-css/core": "workspace:*",
		"escalade": "^3.2.0",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "^0.28.0",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
