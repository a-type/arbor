{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "es2020",
		"lib": ["es2020", "dom"],
		"types": ["node"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"composite": false,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src"]
}
