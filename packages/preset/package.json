{
	"name": "@arbor-css/preset",
	"version": "0.0.108",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"node": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./config": {
			"import": "./dist/define.js",
			"node": "./dist/define.js",
			"types": "./dist/define.d.ts",
			"default": "./dist/define.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "tsc -w --preserveWatchOutput",
		"prepublishOnly": "pnpm build",
		"test": "vitest",
		"test:ci": "vitest --run"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@arbor-css/globals": "workspace:*",
		"@arbor-css/modes": "workspace:*",
		"@arbor-css/tokens": "workspace:*",
		"@arbor-css/util": "workspace:*",
		"@arbor-css/functions": "workspace:*",
		"@arbor-css/css-eval": "workspace:*"
	}
}
