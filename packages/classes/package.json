{
	"name": "@arbor-css/classes",
	"version": "0.0.13",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"node": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "pnpm run --filter @arbor-css/classes --parallel \"/^dev:.*/\"",
		"dev:ts": "tsc -w --preserveWatchOutput",
		"dev:demo": "vite ./demo",
		"test": "vitest",
		"test:ci": "vitest --run",
		"demo": "vite ./demo --port 5174",
		"prepublishOnly": "pnpm build"
	},
	"peerDependencies": {
		"@arbor-css/core": "*"
	},
	"dependencies": {
		"@arbor-css/util": "workspace:*",
		"@unocss/core": "catalog:",
		"@unocss/extractor-arbitrary-variants": "^66.6.8",
		"@unocss/preset-mini": "^66.6.8",
		"@unocss/rule-utils": "^66.6.8",
		"unocss": "catalog:"
	},
	"devDependencies": {
		"@arbor-css/core": "workspace:*",
		"@arbor-css/colors": "workspace:*",
		"@arbor-css/globals": "workspace:*",
		"@arbor-css/preset": "workspace:*",
		"@base-ui/react": "^1.4.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser-playwright": "catalog:",
		"clsx": "^2.1.1",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
