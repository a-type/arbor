{
	"name": "@arbor-css/css-eval",
	"version": "0.0.135",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./node": {
			"import": "./dist/node.js",
			"node": "./dist/node.js",
			"types": "./dist/node.d.ts",
			"default": "./dist/node.js"
		},
		"./browser": {
			"import": "./dist/browser.js",
			"browser": "./dist/browser.js",
			"types": "./dist/browser.d.ts",
			"default": "./dist/browser.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "tsc -w --preserveWatchOutput",
		"prepublishOnly": "pnpm build",
		"test": "vitest",
		"test:ci": "vitest --run"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"lightningcss-wasm": "1.32.0",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@arbor-css/tokens": "workspace:*",
		"@arbor-css/util": "workspace:*",
		"lightningcss": "^1.32.0"
	}
}
