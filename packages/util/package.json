{
	"name": "@arbor-css/util",
	"version": "0.0.117",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/a-type/arbor"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"node": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./config-loader": {
			"import": "./dist/configLoader.js",
			"node": "./dist/configLoader.js",
			"types": "./dist/configLoader.d.ts",
			"default": "./dist/configLoader.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "tsc -w --preserveWatchOutput",
		"prepublishOnly": "pnpm build",
		"test": "vitest",
		"test:ci": "vitest --run"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {}
}
